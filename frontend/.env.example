# Base URL of the backend API.
# Local dev: leave unset — the app defaults to http://127.0.0.1:8000.
# Production: set to your deployed backend, e.g. https://snippet-finder-api.onrender.com
VITE_API_URL=

# Cloudflare Turnstile site key (register / forgot-password bot protection).
# Local dev: leave unset — defaults to Cloudflare's official test key, which
# always passes and pairs with the backend's default test secret key.
# Production: set to your real Turnstile site key.
VITE_TURNSTILE_SITE_KEY=
